# CaptainLabs API backend production env
# Copy to /etc/captainlabs/api.env on the VPS and fill in secrets.

NODE_ENV=production
PORT=8000
APP_NAME=Captains Prediction Companion
APP_VERSION=1.0.0

# Persistent writable state outside the repo
APP_DATA_FILE=/var/lib/captains/notes.json
PIPELINE_STATE_FILE=/var/lib/captains/pipeline-state.json
PIPELINE_OUTPUT_FILE=/var/lib/captains/pipeline-card-outputs.json
CAPTAINLABS_STATE_FILE=/var/lib/captains/captainlabs-state.json

# Optional runtime features
ENABLE_NOTE_TOOLS=false
PIPELINE_SEED_URLS=
PIPELINE_CALENDAR_URL=
PIPELINE_CALENDAR_LIMIT=

# Hermes / model provider settings
HERMES_PROVIDER=gemini
HERMES_COMMAND=hermes
EVENT_MARKET_ALPHA_PROVIDER=gemini
EVENT_MARKET_ALPHA_MODEL=gemini-2.5-flash
GEMINI_MODEL=
IMPLICATIONS_MODEL=
VALIDATION_MODEL=

# Add any provider credentials required by your Hermes/Gemini setup below.
# Example placeholders only:
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
