[Unit]
Description=CaptainLabs API backend
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/srv/captainlabs
EnvironmentFile=/etc/captainlabs/api.env
ExecStart=/usr/bin/env node /srv/captainlabs/src/server.js
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/captains

[Install]
WantedBy=multi-user.target
