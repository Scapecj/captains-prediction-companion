[Unit]
Description=CaptainLabs frontend
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/srv/captainlabs/frontend
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=BACKEND_URL=http://127.0.0.1:8000
Environment=MCP_SERVER_URL=http://127.0.0.1:8000/mcp
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/srv/captainlabs/frontend

[Install]
WantedBy=multi-user.target
